{
  "name": "notpadd-integrations",
  "type": "module",
  "version": "3.0.4",
  "description": "Utils for integrating Notpadd into your project",
  "author": "Bossadi Zenith <hello@bossadizenith.me>",
  "license": "MIT",
  "homepage": "https://notpadd.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/code-env/not-padd.git",
    "directory": "packages/integrations"
  },
  "bugs": "https://github.com/code-env/not-padd/issues",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts -d dist"
  },
  "devDependencies": {
    "@types/node": "20",
    "notpadd-core": "workspace:*",
    "tsdown": "0.21.0-beta.2",
    "typescript": "^5.5.4"
  },
  "peerDependencies": {
    "notpadd-core": "3.0.4"
  }
}
